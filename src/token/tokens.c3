module lsp;

import std::core::dstring;
import std::collections::list;
import c3::lexer;

alias TokenList = List{Token};

// Semantic token categories for LSP semantic highlighting.
// The index value corresponds to the position in TOKEN_TYPES_LEGEND.
enum SemanticCategory : char (int index)
{
	NAMESPACE   { 0 },
	TYPE        { 1 },
	ENUM_CAT    { 2 },
	STRUCT_CAT  { 3 },
	VARIABLE    { 4 },
	FUNCTION    { 5 },
	MACRO_CAT   { 6 },
	KEYWORD     { 7 },
	DECORATOR   { 8 },
	COMMENT     { 9 },
	STRING_CAT  { 10 },
	NUMBER      { 11 },
	OPERATOR    { 12 },
	ENUM_MEMBER { 13 },
	CLASS       { 14 },
	PARAMETER   { 15 },
	PROPERTY    { 16 },
	// Reuses the standard "typeParameter" legend slot as a "declaration
	// accent" color: the fn/macro keyword plus a *primitive* return type
	// (void, int, bool, ...), so `fn void foo(...)` reads as one visual
	// unit distinct from other keywords. A class return type is left as
	// TYPE instead ‚Äî it renders as a regular (green) type reference.
	DECL_ACCENT { 17 },
	SKIP        { -1 },
}

// Maps a TokenType to its semantic token category index.
// The LSP owns all syntax coloring: it emits a semantic token for every
// meaningful token so VS Code colors from the lexer (accurate) rather than
// relying on the TextMate grammar's regex approximation. Only operators,
// punctuation and structural tokens are left uncolored (SKIP).
fn SemanticCategory map_token_type(TokenType t)
{
	switch (t)
	{
		// Identifiers ‚Äî kind is confirmed by the lexer.
		// IDENT may be refined to FUNCTION / NAMESPACE in the encoder
		// based on the following token ( "(" or "::" ).
		case TYPE_IDENT:
		case AT_TYPE_IDENT:
		case HASH_TYPE_IDENT:
		case CT_TYPE_IDENT:
			return TYPE;
		case CONST_IDENT:
		case AT_CONST_IDENT:
		case HASH_CONST_IDENT:
		case CT_CONST_IDENT:
			return ENUM_MEMBER;
		case IDENT:
		case HASH_IDENT:
			return VARIABLE;
		case CT_IDENT:
			return MACRO_CAT;

		// Decorators ‚Äî @attributes
		case AT_INLINE:
		case AT_PURE:
		case AT_NOINLINE:
		case AT_IDENT:
			return DECORATOR;

		// Builtin types ‚Äî colored like user types.
		case VOID:
		case BOOL:
		case CHAR:
		case ICHAR:
		case SHORT:
		case USHORT:
		case INT:
		case UINT:
		case LONG:
		case ULONG:
		case INT128:
		case UINT128:
		case FLOAT:
		case DOUBLE:
		case FLOAT16:
		case BFLOAT16:
		case FLOAT128:
		case IPTR:
		case UPTR:
		case ISZ:
		case USZ:
		case FAULT:
		case ANY:
		case TYPEID:
			return TYPE;

		// Comments and contracts
		case LINE_COMMENT:
		case BLOCK_COMMENT:
		case CONTRACT:
			return COMMENT;

		// String / char / bytes literals
		case STRING:
		case CHAR_LITERAL:
		case BYTES:
			return STRING_CAT;

		// Numeric literals
		case INTEGER:
		case REAL:
			return NUMBER;

		// Keywords ‚Äî declarations, control flow, storage, literals.
		case ALIAS:
		case ASM:
		case ASSERT:
		case ATTRDEF:
		case BITSTRUCT:
		case CONST:
		case CONSTDEF:
		case ENUM:
		case FAULTDEF:
		case FUNC:
		case IMPORT:
		case INTERFACE:
		case MACRO:
		case MODULE:
		case STRUCT:
		case UNION:
		case TYPEDEF:
		case BREAK:
		case CASE:
		case CATCH:
		case CONTINUE:
		case DEFAULT:
		case DEFER:
		case DO:
		case ELSE:
		case EXTERN:
		case FALSE:
		case FOR:
		case FOREACH:
		case FOREACH_R:
		case IF:
		case INLINE:
		case LENGTHOF:
		case NEXTCASE:
		case NULL:
		case RETURN:
		case STATIC:
		case SWITCH:
		case TLOCAL:
		case TRUE:
		case TRY:
		case VAR:
		case WHILE:
			return KEYWORD;

		// Compile-time ($) keywords and the $$ builtin intrinsic.
		case CT_ALIGNOF:
		case CT_ASSERT:
		case CT_ASSIGNABLE:
		case CT_CASE:
		case CT_DEFAULT:
		case CT_DEFINED:
		case CT_ECHO:
		case CT_ELSE:
		case CT_ENDFOR:
		case CT_ENDFOREACH:
		case CT_ENDIF:
		case CT_ENDSWITCH:
		case CT_ERROR:
		case CT_EVAL:
		case CT_EVALTYPE:
		case CT_EXEC:
		case CT_EXTNAMEOF:
		case CT_FEATURE:
		case CT_FOR:
		case CT_FOREACH:
		case CT_IF:
		case CT_IS_CONST:
		case CT_INCLUDE:
		case CT_KINDOF:
		case CT_NAMEOF:
		case CT_OFFSETOF:
		case CT_QNAMEOF:
		case CT_SIZEOF:
		case CT_STRINGIFY:
		case CT_SWITCH:
		case CT_TYPEFROM:
		case CT_TYPEOF:
		case CT_VAARG:
		case CT_VACONST:
		case CT_VACOUNT:
		case CT_VAEXPR:
		case CT_VAREF:
		case CT_VATYPE:
		case CT_VASPLAT:
		case BUILTIN:
			return KEYWORD;

		// Operators, assignment, comparison, punctuation and structure
		// tokens stay uncolored.
		default:
			return SKIP;
	}
}

// Check if a character is a path separator (/ or \).
fn bool is_path_separator(char c)
{
	return c == '/' || c == '\\';
}

// Check if a string starts with a Windows drive letter pattern (e.g. "C:/" or "C:\").
fn bool is_windows_drive_path(String s)
{
	if (s.len < 3) return false;
	char c = s[0];
	if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z'))) return false;
	return s[1] == ':' && is_path_separator(s[2]);
}

// Checks if a token is a base type or type identifier (used for variable declarations).
fn bool is_type_token(TokenType t)
{
	switch (t)
	{
		case VOID:
		case BOOL:
		case CHAR:
		case ICHAR:
		case SHORT:
		case USHORT:
		case INT:
		case UINT:
		case LONG:
		case ULONG:
		case INT128:
		case UINT128:
		case FLOAT:
		case DOUBLE:
		case FLOAT16:
		case BFLOAT16:
		case FLOAT128:
		case IPTR:
		case UPTR:
		case ISZ:
		case USZ:
		case FAULT:
		case ANY:
		case TYPEID:
		case TYPE_IDENT:
		case VAR:
			return true;
		default:
			return false;
	}
}

// Checks if a token is a builtin primitive type (void, int, bool, ...), as
// opposed to a user-defined type name (TYPE_IDENT). Used to decide whether a
// function's return type gets the primitive declaration-accent color or is
// left as a regular (green) type reference.
fn bool is_builtin_type_token(TokenType t)
{
	switch (t)
	{
		case VOID:
		case BOOL:
		case CHAR:
		case ICHAR:
		case SHORT:
		case USHORT:
		case INT:
		case UINT:
		case LONG:
		case ULONG:
		case INT128:
		case UINT128:
		case FLOAT:
		case DOUBLE:
		case FLOAT16:
		case BFLOAT16:
		case FLOAT128:
		case IPTR:
		case UPTR:
		case ISZ:
		case USZ:
		case FAULT:
		case ANY:
		case TYPEID:
			return true;
		default:
			return false;
	}
}

// Checks if a token introduces a type or constant declaration.
fn bool is_type_declaration_keyword(TokenType t)
{
	switch (t)
	{
		case STRUCT:
		case UNION:
		case BITSTRUCT:
		case ENUM:
		case FAULTDEF:
		case INTERFACE:
		case TYPEDEF:
		case CONSTDEF:
		case ALIAS:
			return true;
		default:
			return false;
	}
}

// Checks if a token is an identifier (IDENT or AT_IDENT for macro names like @foo).
fn bool is_ident(TokenType t)
{
	return t == IDENT || t == AT_IDENT;
}

// --- Balanced-brace / module-path helpers -----------------------------------
// C3 generics use braces at call/declaration sites (`Foo{int}`, `foo{Bar}(...)`,
// `fn List{int} get_list()`), so a `{` is not necessarily a function body. The
// scanners below let forward/backward walks skip a balanced `{...}` block instead
// of stopping at the first brace. Reused across completion/definition/signature/
// symbols to avoid the same depth-counting loop being copy-pasted everywhere.

// Given the index of an LBRACE token, returns the index of its matching RBRACE.
// Returns self.size if the braces are unbalanced (caller treats it as end-of-scan).
fn sz TokenList.match_rbrace(&self, sz lbrace_idx)
{
	sz depth = 0;
	for (sz j = lbrace_idx; j < self.size; j++)
	{
		TokenType t = self.entries[j].type;
		if (t == LBRACE)
		{
			depth++;
		}
		else if (t == RBRACE)
		{
			depth--;
			if (depth == 0) return j;
		}
	}
	return self.size;
}

// Given the index of an RBRACE token, returns the index of its matching LBRACE by
// scanning backward. Returns self.size if the braces are unbalanced.
fn sz TokenList.match_lbrace_back(&self, sz rbrace_idx)
{
	sz depth = 0;
	for (sz j = rbrace_idx; ; j--)
	{
		TokenType t = self.entries[j].type;
		if (t == RBRACE)
		{
			depth++;
		}
		else if (t == LBRACE)
		{
			depth--;
			if (depth == 0) return j;
		}
		if (j == 0) break;
	}
	return self.size;
}

// Builds the "a::b::c" module path from the tokens following a MODULE keyword at
// mod_idx: accumulates ident/type/const segments, skips SCOPE (::), and stops at
// the first other token (e.g. EOS, or `<` of a generic module declaration).
fn String TokenList.module_path_at(&self, sz mod_idx)
{
	DString path = dstring::temp();
	bool first = true;
	for (sz j = mod_idx + 1; j < self.size; j++)
	{
		TokenType t = self.entries[j].type;
		if (is_ident(t) || t == TYPE_IDENT || t == CONST_IDENT)
		{
			if (!first) path.append("::");
			path.append(self.entries[j].text);
			first = false;
		}
		else if (t == SCOPE)
		{
			continue;
		}
		else
		{
			break;
		}
	}
	return path.str_view();
}

// Returns the module path of the declaration at decl_idx by scanning backward to
// the nearest preceding MODULE keyword (or "" if the declaration is module-less).
fn String TokenList.module_of_decl(&self, sz decl_idx)
{
	for (sz j = decl_idx; ; j--)
	{
		if (self.entries[j].type == MODULE) return self.module_path_at(j);
		if (j == 0) break;
	}
	return "";
}

// From decl_idx, find the first `{` and return the index of its matching `}`, so a
// loop iterating top-level declarations can skip a type body `{...}` (e.g. an
// interface's method declarations, which must not be scanned as module functions).
// Returns decl_idx unchanged when there is no body before the end of the declaration.
fn sz TokenList.skip_type_body(&self, sz decl_idx)
{
	for (sz j = decl_idx; j < self.size; j++)
	{
		if (self.entries[j].type == LBRACE) return self.match_rbrace(j);
		if (self.entries[j].type == EOS) return decl_idx;
	}
	return decl_idx;
}

// Returns a human-readable description for a token (used in hover).
fn String get_token_description(TokenType t, String text)
{
	switch (t)
	{
		// Keywords
		case ALIAS: return "`alias` ‚Äî Defines a type alias";
		case ASM: return "`asm` ‚Äî Inline assembly block";
		case ASSERT: return "`assert` ‚Äî Runtime assertion";
		case ATTRDEF: return "`attrdef` ‚Äî Defines a custom attribute";
		case BITSTRUCT: return "`bitstruct` ‚Äî Bit-level struct definition";
		case BREAK: return "`break` ‚Äî Exits the current loop or switch";
		case CASE: return "`case` ‚Äî Branch in a switch statement";
		case CATCH: return "`catch` ‚Äî Catches an optional fault value";
		case CONST: return "`const` ‚Äî Compile-time constant declaration";
		case CONSTDEF: return "`constdef` ‚Äî Defines a named constant";
		case CONTINUE: return "`continue` ‚Äî Skips to next loop iteration";
		case DEFAULT: return "`default` ‚Äî Default branch in switch";
		case DEFER: return "`defer` ‚Äî Defers statement execution to scope exit";
		case DO: return "`do` ‚Äî Do-while loop";
		case ELSE: return "`else` ‚Äî Alternative branch";
		case ENUM: return "`enum` ‚Äî Enumeration type definition";
		case EXTERN: return "`extern` ‚Äî External linkage declaration";
		case FALSE: return "`false` ‚Äî Boolean false literal";
		case FAULTDEF: return "`faultdef` ‚Äî Defines a fault type";
		case FOR: return "`for` ‚Äî For loop";
		case FOREACH: return "`foreach` ‚Äî Iterates over elements";
		case FOREACH_R: return "`foreach_r` ‚Äî Reverse iteration";
		case FUNC: return "`fn` ‚Äî Function declaration";
		case IF: return "`if` ‚Äî Conditional branch";
		case IMPORT: return "`import` ‚Äî Imports a module";
		case INLINE: return "`inline` ‚Äî Hint to inline a function";
		case INTERFACE: return "`interface` ‚Äî Interface definition";
		case LENGTHOF: return "`lengthof` ‚Äî Returns the length of an array or container";
		case MACRO: return "`macro` ‚Äî Macro definition";
		case MODULE: return "`module` ‚Äî Module declaration";
		case NEXTCASE: return "`nextcase` ‚Äî Falls through to next case";
		case NULL: return "`null` ‚Äî Null pointer literal";
		case RETURN: return "`return` ‚Äî Returns from function";
		case STATIC: return "`static` ‚Äî Static storage or scope";
		case STRUCT: return "`struct` ‚Äî Struct type definition";
		case SWITCH: return "`switch` ‚Äî Multi-way branch";
		case TLOCAL: return "`tlocal` ‚Äî Thread-local storage";
		case TRUE: return "`true` ‚Äî Boolean true literal";
		case TRY: return "`try` ‚Äî Unwraps an optional, returning on fault";
		case TYPEDEF: return "`typedef` ‚Äî Defines a distinct type";
		case UNION: return "`union` ‚Äî Union type definition";
		case VAR: return "`var` ‚Äî Variable with inferred type";
		case WHILE: return "`while` ‚Äî While loop";

		// Builtin types
		case VOID: return "`void` ‚Äî No value type";
		case BOOL: return "`bool` ‚Äî Boolean type (true/false)";
		case CHAR: return "`char` ‚Äî 8-bit unsigned character";
		case ICHAR: return "`ichar` ‚Äî 8-bit signed character";
		case SHORT: return "`short` ‚Äî 16-bit signed integer";
		case USHORT: return "`ushort` ‚Äî 16-bit unsigned integer";
		case INT: return "`int` ‚Äî 32-bit signed integer";
		case UINT: return "`uint` ‚Äî 32-bit unsigned integer";
		case LONG: return "`long` ‚Äî 64-bit signed integer";
		case ULONG: return "`ulong` ‚Äî 64-bit unsigned integer";
		case INT128: return "`int128` ‚Äî 128-bit signed integer";
		case UINT128: return "`uint128` ‚Äî 128-bit unsigned integer";
		case FLOAT: return "`float` ‚Äî 32-bit floating point";
		case DOUBLE: return "`double` ‚Äî 64-bit floating point";
		case FLOAT16: return "`float16` ‚Äî 16-bit floating point";
		case BFLOAT16: return "`bfloat16` ‚Äî 16-bit brain floating point";
		case FLOAT128: return "`float128` ‚Äî 128-bit floating point";
		case IPTR: return "`iptr` ‚Äî Signed pointer-sized integer";
		case UPTR: return "`uptr` ‚Äî Unsigned pointer-sized integer";
		case ISZ: return "`sz` ‚Äî Signed size type";
		case USZ: return "`usz` ‚Äî Unsigned size type";
		case FAULT: return "`fault` ‚Äî Fault type for error handling";
		case ANY: return "`any` ‚Äî Type-erased interface type";
		case TYPEID: return "`typeid` ‚Äî Runtime type identifier";

		// Compile-time intrinsics
		case CT_ALIGNOF: return "`$alignof` ‚Äî Returns alignment of a type";
		case CT_ASSERT: return "`$assert` ‚Äî Compile-time assertion";
		case CT_ASSIGNABLE: return "`$assignable` ‚Äî Checks if a value is assignable";
		case CT_CASE: return "`$case` ‚Äî Compile-time case";
		case CT_DEFAULT: return "`$default` ‚Äî Compile-time default case";
		case CT_DEFINED: return "`$defined` ‚Äî Checks if an identifier is defined";
		case CT_ECHO: return "`$echo` ‚Äî Compile-time message output";
		case CT_ELSE: return "`$else` ‚Äî Compile-time else branch";
		case CT_ENDFOR: return "`$endfor` ‚Äî Ends compile-time for";
		case CT_ENDFOREACH: return "`$endforeach` ‚Äî Ends compile-time foreach";
		case CT_ENDIF: return "`$endif` ‚Äî Ends compile-time if";
		case CT_ENDSWITCH: return "`$endswitch` ‚Äî Ends compile-time switch";
		case CT_ERROR: return "`$error` ‚Äî Emits a compile-time error";
		case CT_EVAL: return "`$eval` ‚Äî Compile-time expression evaluation";
		case CT_EVALTYPE: return "`$evaltype` ‚Äî Evaluates to a type at compile time";
		case CT_EXEC: return "`$exec` ‚Äî Executes a compile-time command";
		case CT_EXTNAMEOF: return "`$extnameof` ‚Äî External name of a symbol";
		case CT_FEATURE: return "`$feature` ‚Äî Checks for a compile-time feature";
		case CT_FOR: return "`$for` ‚Äî Compile-time for loop";
		case CT_FOREACH: return "`$foreach` ‚Äî Compile-time foreach loop";
		case CT_IF: return "`$if` ‚Äî Compile-time conditional";
		case CT_IS_CONST: return "`$is_const` ‚Äî Checks if expression is constant";
		case CT_INCLUDE: return "`$include` ‚Äî Includes a file at compile time";
		case CT_KINDOF: return "`$kindof` ‚Äî Returns the kind of a type";
		case CT_NAMEOF: return "`$nameof` ‚Äî Returns the name of a symbol";
		case CT_OFFSETOF: return "`$offsetof` ‚Äî Returns field offset in bytes";
		case CT_QNAMEOF: return "`$qnameof` ‚Äî Returns qualified name of a symbol";
		case CT_SIZEOF: return "`$sizeof` ‚Äî Returns size of a type in bytes";
		case CT_STRINGIFY: return "`$stringify` ‚Äî Converts expression to string";
		case CT_SWITCH: return "`$switch` ‚Äî Compile-time switch";
		case CT_TYPEFROM: return "`$typefrom` ‚Äî Creates type from typeid";
		case CT_TYPEOF: return "`$typeof` ‚Äî Returns the type of an expression";
		case CT_VAARG: return "`$vaarg` ‚Äî Accesses variadic argument";
		case CT_VACONST: return "`$vaconst` ‚Äî Variadic constant access";
		case CT_VACOUNT: return "`$vacount` ‚Äî Returns number of variadic arguments";
		case CT_VAEXPR: return "`$vaexpr` ‚Äî Variadic expression access";
		case CT_VAREF: return "`$varef` ‚Äî Variadic reference access";
		case CT_VATYPE: return "`$vatype` ‚Äî Variadic type access";
		case CT_VASPLAT: return "`$vasplat` ‚Äî Splats variadic arguments";
		case BUILTIN: return "`$$` ‚Äî Builtin intrinsic access";

		// Identifier types
		case TYPE_IDENT:
		case AT_TYPE_IDENT:
		case HASH_TYPE_IDENT:
		case CT_TYPE_IDENT:
			DString d = dstring::temp();
			d.append("Type: `");
			d.append(text);
			d.append_char('`');
			return d.str_view();
		case CONST_IDENT:
		case AT_CONST_IDENT:
		case HASH_CONST_IDENT:
		case CT_CONST_IDENT:
			DString d = dstring::temp();
			d.append("Constant: `");
			d.append(text);
			d.append_char('`');
			return d.str_view();
		case IDENT:
		case AT_IDENT:
		case HASH_IDENT:
		case CT_IDENT:
			DString d = dstring::temp();
			d.append("Identifier: `");
			d.append(text);
			d.append_char('`');
			return d.str_view();

		default:
			return "";
	}
}
